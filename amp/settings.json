{
  "amp.dangerouslyAllowAll": true,
  "amp.gauge": "tokens",
  "amp.git.commit.ampThread.enabled": false,
  "amp.git.commit.coauthor.enabled": false,
  "amp.internal.deepReasoningEffort": "xhigh",
  "amp.remoteThreadCreation.enabled": true,
  "amp.mcpServers": {
    "ffmpeg-mcp": {
      "args": ["-y", "mcp-ffmpeg@1.0.5"],
      "command": "npx"
    },
    "sem": {
      "args": ["mcp"],
      "command": "/opt/homebrew/bin/sem"
    },
    "readai": {
      "args": ["-y", "mcp-remote", "https://api.read.ai/mcp"],
      "command": "npx"
    }
  },
  "amp.permissions": [
    {
      "action": "ask",
      "tool": "Bash"
    },
    {
      "action": "ask",
      "tool": "mcp__*"
    },
    {
      "action": "delegate",
      "to": "my-permission-helper",
      "tool": "*"
    }
  ],
  "amp.updates.mode": "auto",
  "amp.showCosts": false
}
